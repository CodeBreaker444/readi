meta {
  name: Get Agent Usage
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/agent/usage
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns aggregated AI agent usage statistics across all users in the organization (total queries, per-user breakdown, monthly trends). Used by admins to monitor consumption.

  **Auth:** Session cookie (`readi_auth_token`).

  **Used in:**
  - `src/components/ai/AiUsageWidget.tsx` — usage dashboard widget showing org-wide AI consumption
}

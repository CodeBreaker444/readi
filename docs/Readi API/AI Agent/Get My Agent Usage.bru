meta {
  name: Get My Agent Usage
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/agent/usage/me
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns AI agent usage stats for the currently authenticated user — total queries made, remaining allowance, and current period usage.

  **Auth:** Session cookie (`readi_auth_token`).

  **Used in:**
  - `src/components/TopBar.tsx` — displays the user's personal AI query usage count when the chat panel is opened
}

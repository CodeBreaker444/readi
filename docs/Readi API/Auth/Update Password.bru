meta {
  name: Update Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/update-password
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "current_password": "old_password",
    "new_password": "new_secure_password"
  }
}

settings {
  encodeUrl: true
}

docs {
  Update user password. Requires active session.
}

meta {
  name: Get Compliance Calendar
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/compliance/calendar
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns compliance-related events formatted for calendar display: audit dates, review deadlines, and certification expiry dates.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_compliance` permission.

  **Used in:**
  - Compliance calendar view page
}
meta {
  name: Add Mission Communication
  type: http
  seq: 22
}

post {
  url: {{baseUrl}}/api/evaluation/mission/communication/add
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "mission_id": 1,
    "message": "Mission approved for execution"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Sends a communication message in the context of a planning mission.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - Planning mission detail — "Send Communication" form
}
meta {
  name: Add Mission Planning
  type: http
  seq: 16
}

post {
  url: {{baseUrl}}/api/evaluation/planning/add-mission-planning
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "planning_id": 1,
    "mission_template_id": 2,
    "scheduled_date": "2026-04-20"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Adds a new mission to a planning record (links an operation to the planning workflow).

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - `src/components/planning/PlanningMissionContent.tsx` — "Add Mission" form in the planning detail view
}
meta {
  name: Assign Evaluation
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/api/evaluation/:id/assignment
  body: json
  auth: inherit
}

params:path {
  id: 1
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "assigned_user_id": 3,
    "role": "LEAD"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Assigns an evaluator user to an evaluation request.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Planning evaluation management — evaluator assignment
}
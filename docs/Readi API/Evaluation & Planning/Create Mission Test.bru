meta {
  name: Create Mission Test
  type: http
  seq: 19
}

post {
  url: {{baseUrl}}/api/evaluation/mission/mission-test
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "mission_id": 1,
    "test_date": "2026-04-18",
    "test_notes": "Initial test flight"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Creates a mission test/trial record associated with an evaluation, recording test parameters and outcomes.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Evaluation detail — "Create Test" form
}
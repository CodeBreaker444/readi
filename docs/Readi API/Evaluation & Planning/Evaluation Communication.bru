meta {
  name: Evaluation Communication
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/api/evaluation/:id/communication
  body: json
  auth: inherit
}

params:path {
  id: 1
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "message": "Evaluation review scheduled",
    "recipients": [1, 2]
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Sends a communication in the context of an evaluation request.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Evaluation detail — communications section
}
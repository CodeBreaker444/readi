meta {
  name: Get Evaluation Tasks
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/evaluation/:id/tasks
  body: none
  auth: inherit
}

params:path {
  id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns the checklist tasks associated with an evaluation request — items the evaluator must complete or verify.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Evaluation detail view — tasks/checklist tab
}
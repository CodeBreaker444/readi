meta {
  name: Get Mission List
  type: http
  seq: 18
}

get {
  url: {{baseUrl}}/api/evaluation/mission/list
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns the list of operations/missions available for linking to a planning or evaluation record.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - Planning forms — mission selection dropdown
}
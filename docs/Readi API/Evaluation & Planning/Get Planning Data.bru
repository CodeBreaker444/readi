meta {
  name: Get Planning Data
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/api/evaluation/planning
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns detailed data for a specific planning mission: logbook, drone options, repository files, and mission configuration.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - `src/components/planning/PlanningMissionContent.tsx` — loads all planning data on mission open
}
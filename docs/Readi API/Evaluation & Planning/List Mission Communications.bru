meta {
  name: List Mission Communications
  type: http
  seq: 21
}

get {
  url: {{baseUrl}}/api/evaluation/mission/communication/list?mission_id=1
  body: none
  auth: inherit
}

params:query {
  mission_id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns all communications sent for a specific mission/planning record.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - Planning mission detail — communications history tab
}
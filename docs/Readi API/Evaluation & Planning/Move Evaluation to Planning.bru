meta {
  name: Move Evaluation to Planning
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/evaluation/:id/move-to-planning
  body: json
  auth: inherit
}

params:path {
  id: 1
}

headers {
  Content-Type: application/json
}

body:json {
  {}
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Promotes an approved evaluation into a planning mission, creating the planning record and linking it to the evaluation.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Evaluation detail — "Move to Planning" action after evaluation is approved
}
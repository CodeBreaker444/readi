meta {
  name: Update Evaluation
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/evaluation/:id
  body: json
  auth: inherit
}

params:path {
  id: 1
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "evaluation_status": "IN_PROGRESS",
    "evaluation_description": "Updated description"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Updates an evaluation request's fields (status, notes, mission data, assigned evaluator).

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - `src/components/planning/EvaluationEditSheet.tsx` — evaluation edit side panel
}
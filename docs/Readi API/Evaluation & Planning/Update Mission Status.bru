meta {
  name: Update Mission Status
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/api/evaluation/mission/update-status
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "mission_id": 1,
    "status": "APPROVED"
  }
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Updates the status of a planning mission (e.g. PENDING ? IN_REVIEW ? APPROVED).

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning` permission.

  **Used in:**
  - Planning mission status workflow controls
}
meta {
  name: Upload Evaluation Files
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/evaluation/new-req/files/upload
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  file: @file()
  evaluation_id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Uploads files to an evaluation request's document repository (site maps, surveys, regulatory documents).

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - Evaluation detail — file upload action
}
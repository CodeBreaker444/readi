meta {
  name: Export Data
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/export
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "entity_type": "operations",
    "format": "xlsx",
    "filters": {
      "date_from": "2026-01-01",
      "date_to": "2026-04-30",
      "status": "COMPLETED"
    }
  }
}

settings {
  encodeUrl: true
}

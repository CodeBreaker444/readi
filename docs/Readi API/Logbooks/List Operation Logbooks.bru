meta {
  name: List Operation Logbooks
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/logbooks/operation/list
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns a list of operation logbook entries with summary data including mission details, pilot, drone, and outcome.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_logbooks` permission.

  **Used in:**
  - `src/app/logbooks/page.tsx` — Logbooks page — operations tab
}
meta {
  name: Add Mission Result
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/api/mission/result/add
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "result_name": "SUCCESS",
    "result_label": "Mission Successful",
    "color": "#28a745"
  }
}

settings {
  encodeUrl: true
}

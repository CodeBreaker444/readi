meta {
  name: Delete Checklist
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/api/organization/checklist/:id
  body: none
  auth: inherit
}

params:path {
  id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Permanently deletes a checklist template.

  **Auth:** Session cookie (`readi_auth_token`). Requires admin/config permission.

  **Used in:**
  - `src/app/organization/checklists/page.tsx` — delete confirmation on checklist items
}
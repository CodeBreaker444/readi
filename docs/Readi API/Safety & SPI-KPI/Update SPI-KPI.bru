meta {
  name: Update SPI/KPI
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/safety/spi-kpi/save
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "id": 1,
    "indicator_name": "Updated Incident Rate",
    "target_value": 1.5,
    "unit": "%",
    "frequency": "QUARTERLY",
    "is_active": 1
  }
}

settings {
  encodeUrl: true
}

docs {
  Update existing SPI/KPI by including `id` field.
}

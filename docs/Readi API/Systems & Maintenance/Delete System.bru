meta {
  name: Delete System
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/system/:id/delete
  body: none
  auth: inherit
}

params:path {
  id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Removes a drone system record from the organization. Will fail if the system has active operations.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_config` permission.

  **Used in:**
  - `src/app/systems/manage/page.tsx` — delete confirmation on system items
}
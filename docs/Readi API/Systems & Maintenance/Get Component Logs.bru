meta {
  name: Get Component Logs
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/system/component/:id/logs
  body: none
  auth: inherit
}

params:path {
  id: 1
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns flight/usage logs for a specific component showing accumulated hours, cycles, and maintenance events.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_config` permission.

  **Used in:**
  - Component detail view — usage history tab
}
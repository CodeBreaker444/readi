meta {
  name: List Component Types
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/system/component-types
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns all component type categories (e.g. BATTERY, CAMERA, PROPELLER, SENSOR). Used to classify components when adding them.

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_config` permission.

  **Used in:**
  - `src/app/systems/manage/page.tsx` — component type dropdown
}
meta {
  name: List Models
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/api/system/model/list
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  **Purpose:** Returns all drone model definitions used to classify systems (e.g. DJI Matrice 300, Parrot ANAFI).

  **Auth:** Session cookie (`readi_auth_token`). Requires `view_config` permission.

  **Used in:**
  - `src/app/systems/manage/page.tsx` — model dropdown when adding/editing a system
}
meta {
  name: Assign Flight Request to Planning
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/planning/flight-requests/assign
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "request_id": 1,
    "planning_id": 42
  }
}

settings {
  encodeUrl: true
}

docs {
  Assigns a DCC flight request to a PMVD planning mission. Triggers DCC acceptance callback automatically.
  planning_id is optional â€” omit to acknowledge without assigning.


**Auth:** Session cookie (`readi_auth_token`). Requires `view_planning_advanced` permission.

  **Used in:**
  - `src/components/operation/FlightRequestsTable.tsx` — "Assign to Planning" action on flight requests
}

meta {
  name: Bulk Mission Cancellation
  type: http
  seq: 6
}

post {
  url: {{dcc_base_url}}/dcc/missions/cancel
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "missionIds": [
      "PM-2025-001",
      "PM-2025-002",
      "PM-2025-003"
    ]
  }
}

settings {
  encodeUrl: true
}

docs {
  Sent by PMVD to DCC when a scheduled program is cancelled. Sends all mission IDs so DCC can remove them.
}

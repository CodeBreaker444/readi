meta {
  name: Get DCC Integration Settings
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/settings/dcc
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
}

docs {
  Returns the configured DCC display name and callback URL for the authenticated organization.


**Auth:** Session cookie (`readi_auth_token`). Requires `view_config` permission.

  **Used in:**
  - Settings page — DCC Integration configuration section
}

  "scripts": {
    "dev": "next dev",
    "dev:docs": "cd fumadocs && npm run dev",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --no-coverage",
    "build": "next build",
    "build:docs": "cd fumadocs && npm run build",
    "prenext:build": "npm run build:docs",
    "ci": "npm run test && npm run test:integration && npm run build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate && fumadocs-mdx",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "cd \"docs/Readi API\" && bru run . -r",
    "test:api:verbose": "cd \"docs/Readi API\" && bru run . -r --verbose",
    "test:api:report": "cd \"docs/Readi API\" && bru run . -r --reporter-html ../../test-results/report.html",
    "prepare": "husky"
  },

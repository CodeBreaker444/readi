/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users_profile {
  profile_id                 Int          @id @default(autoincrement())
  fk_user_id                 Int          @unique
  profile_picture            String?
  bio                        String?
  address                    String?
  city                       String?      @db.VarChar(100)
  state                      String?      @db.VarChar(100)
  postal_code                String?      @db.VarChar(20)
  fk_country_id              Int?
  date_of_birth              DateTime?    @db.Date
  emergency_contact          String?      @db.VarChar(255)
  emergency_phone            String?      @db.VarChar(50)
  certifications             Json?
  skills                     Json?
  created_at                 DateTime?    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?    @default(now()) @db.Timestamp(6)
  user_signature             String?
  user_primary_certification String?      @db.VarChar(300)
  countries                  countries?   @relation(fields: [fk_country_id], references: [country_id], onDelete: NoAction, onUpdate: NoAction)
  users                      public_users @relation(fields: [fk_user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fk_user_id], map: "idx_users_profile_fk_user_id")
  @@schema("public")
}

